debug: 0
logoutput: stderr

internal: SOCKD_BIND_ADDR port = SOCKD_PORT
external: SOCKD_EXTERNAL_IFACE

socksmethod: username
clientmethod: none

user.privileged: root
user.unprivileged: nobody

client pass {
    from: SOCKD_ALLOW_IPS port 1-65535 to: 0.0.0.0/0
    log: connect disconnect error
}

socks pass {
    from: 0.0.0.0/0 to: 0.0.0.0/0
    socksmethod: username
    log: connect disconnect error
}
