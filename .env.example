# Copy this file to .env and fill in your values.

# =============================================================================
# Telemt Proxy Configuration
# =============================================================================

TELEMT_EXTERNAL_PORT=10443

# =============================================================================
# Dante Proxy Configuration
# =============================================================================

# Port the proxy will listen on
SOCKD_PORT=10666

# Proxy credentials
SOCKD_USER_NAME=proxy
SOCKD_USER_PASSWORD=changeme

# Network interface for outbound traffic.
# Leave empty to auto-detect from default route.
SOCKD_EXTERNAL_IFACE=

# IP allowlist for incoming connections (single CIDR).
# Default: 0.0.0.0/0 (any IP). Restrict to your IP for better security:
#   SOCKD_ALLOW_IPS=203.0.113.42/32
SOCKD_ALLOW_IPS=0.0.0.0/0

# =============================================================================
# NaiveProxy Configuration
# =============================================================================

# Domain pointing at this host. Required — used to issue the TLS certificate.
NAIVE_DOMAIN=naive.example.com

# Email used for ACME/TLS certificate registration.
NAIVE_EMAIL=you@example.com

# Proxy credentials
NAIVE_USER_NAME=naive
NAIVE_USER_PASSWORD=changeme

# Site to masquerade as for non-proxy requests (reverse-proxied as decoy content).
NAIVE_MASK_SITE=yastatic.net

# Ports Caddy listens on. HTTP port is also used for the ACME HTTP-01 challenge.
NAIVE_HTTP_PORT=80
NAIVE_HTTPS_PORT=20443

# =============================================================================
# Trojan Configuration
# =============================================================================

# TCP port trojan listens on.
TROJAN_PORT=40443

# Trojan reuses the TLS certificate issued by naive for NAIVE_DOMAIN,
# so no separate domain/email is needed here. Make sure naive is running
# and has obtained a certificate before starting trojan.

# Credentials for the first user (trojan has no concept of usernames,
# only passwords — the name is used for documentation purposes only).
TROJAN_USER_NAME=trojan
TROJAN_USER_PASSWORD=changeme

# =============================================================================
# MieruProxy Configuration
# =============================================================================

# TCP port mita listens on. Must match the "port" set in mieru/mieru-users.json.
MIERU_PORT=30443

# Users, passwords and quotas are configured directly in mieru/mieru-users.json.
# Copy mieru/mieru-users.json.example to mieru/mieru-users.json and edit it.

# =============================================================================
# Monitoring (Node Exporter + cAdvisor)
# =============================================================================

# Node Exporter uses host networking and binds directly on this port.
NODE_EXPORTER_PORT=59900

# cAdvisor is published on this host port (container always listens on 8080).
CADVISOR_PORT=59901
